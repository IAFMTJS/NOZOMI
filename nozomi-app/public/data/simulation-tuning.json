    },
    {
      "pattern": "(うん|そう|ok|yeah|mhm)$",
      "jpBoost": ["？", "どう", "何", "続け", "他に"]
    },
    {
      "pattern": "(疲|忙|大変|tired|busy)",
      "jpBoost": ["お疲れ", "休", "頑張", "大変", "ゆっくり"]
    }
  ],
  "questionOnShortAck": true
}
