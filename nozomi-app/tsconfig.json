{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/features/*": ["src/features/*"],
      "@/systems/speech/*": ["src/features/voice/logic/*"],
      "@/systems/orb/*": ["src/features/orb/logic/*"],
      "@/components/audio/*": ["src/features/voice/ui/*"],
      "@/components/orb/*": ["src/features/orb/ui/*"],
      "@/components/chat/*": ["src/features/chat/ui/*"],
      "@/components/presence/*": ["src/features/presence/ui/*"],
      "@/components/suggestions/*": ["src/features/presence/ui/suggestions/*"],
      "@/contexts/SpeechListenContext": ["src/features/voice/context/SpeechListenContext.tsx"],
      "@/contexts/speech-listen/*": ["src/features/voice/context/speech-listen/*"],
      "@/hooks/useConversation": ["src/features/conversation/useConversation.ts"],
      "@/hooks/useOrbAudioLevel": ["src/features/orb/hooks/useOrbAudioLevel.ts"],
      "@/hooks/useSpeechOutputActive": ["src/features/voice/hooks/useSpeechOutputActive.ts"],
      "@/components/settings/NozomiVoicePicker": ["src/features/voice/ui/NozomiVoicePicker.tsx"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}
