{
  "name": "nozomi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host",
    "dev:host": "vite --host",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "export-data": "node scripts/export-data.mjs && node scripts/fill-romaji.mjs",
    "fill-romaji": "node scripts/fill-romaji.mjs",
    "fill-grammar-tags": "node scripts/fill-grammar-tags.mjs",
    "validate-sentences": "node scripts/validate-sentences.mjs",
    "validate-seed": "vitest run src/database/seedData.validation.test.ts",
    "simulate": "node scripts/run-simulation.mjs",
    "simulate:batch": "node scripts/run-simulation.mjs",
    "simulate:quick": "vitest run src/simulation/simulation.test.ts",
    "simulate:learn": "node scripts/run-simulation-learn.mjs",
    "apply-simulation-insights": "vitest run src/simulation/learning/applyTuning.export.test.ts",
    "import-jmdict": "node scripts/import-jmdict.mjs --export",
    "import-jmdict:dry": "node scripts/import-jmdict.mjs --dry-run --max 500 --no-download"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "dexie": "^4.4.2",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.1",
    "wanakana": "^5.3.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
